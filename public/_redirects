# Cloudflare Pages _redirects — production cutover map.
#
# Preserves search-engine equity from the legacy auto-CMS site at
# loveautogroup.net when DNS cuts over to this Next.js build. Without
# these 301s, every existing inbound link (Google, Yelp, CarGurus,
# Facebook, Yellow Pages, BBB, etc.) would 404 and the dealership's
# accumulated rankings would zero out.
#
# Format: source-pattern  destination  status-code
# 301 = permanent redirect (Google passes ~95% of link equity through)
#
# IMPORTANT: every destination MUST use the trailing-slash form to match
# next.config.ts `trailingSlash: true`. Static export emits
# /<route>/index.html, so the canonical URL is /<route>/. Hitting a
# no-slash destination causes Next.js to re-redirect to the slash form
# and Chrome reports the chain as "Redirect was cancelled" — this is
# the regression caught 2026-04-30 that took /inventory, /reviews, and
# the brand-inventory pages out of Google for hours.

# ─── Existing slug aliases ──────────────────────────────────────────
# TCPA-approved slug alias — our consent language references /privacy
/privacy                     /privacy-policy/                  301
/privacy/                    /privacy-policy/                  301

# Common slug aliases for marketing consistency
/terms-of-service            /terms/                           301
/terms-of-service/           /terms/                           301

# ─── Top-level legacy pages → new equivalents ───────────────────────
# Old auto-CMS top-level URLs from the previous site.
/about-us                    /about/                           301
/about-us/                   /about/                           301
/store                       /contact/                         301
/store/                      /contact/                         301
# /reviews — DO NOT REDIRECT. Real Next.js page now lives at /reviews/.
# Previous redirect (/reviews → /about#reviews) caused a redirect-cancel
# loop AND pointed at an anchor that didn't exist on /about. Verified
# 2026-04-30. If the /reviews page is ever removed, restore a redirect
# to /about/ (NOT /about#reviews) here.
/locatorservice              /sell-your-car/                   301
/locatorservice/             /sell-your-car/                   301
/contact-us                  /contact/                         301
/contact-us/                 /contact/                         301

# ─── Inventory listing pages ────────────────────────────────────────
# Legacy CMS used /newandusedcars and variants
/newandusedcars              /inventory/                       301
/newandusedcars/             /inventory/                       301
/newandusedcars/*            /inventory/                       301

# ─── Common legacy paths from auto-CMS templates ────────────────────
/financing-application       /financing/                       301
/credit-application          /financing/                       301
/apply                       /financing/                       301
/apply/                      /financing/                       301
/apply-online                /financing/                       301
/apply-online/               /financing/                       301
/apply-for-financing         /financing/                       301
/value-your-trade            /sell-your-car/                   301
/trade-in                    /sell-your-car/                   301
/sell-us-your-car            /sell-your-car/                   301
/services                    /                                 301
/parts                       /                                 301
/specials                    /inventory/                       301

# ─── GSC-indexed legacy URLs (added 2026-05-22, Anna v2 deep-dive) ──
# These three URLs are in Google's index from the CarsForSale era
# but don't exist on this Next.js site. Combined they absorbed 5,939
# impressions over the last 365 days with ~0% CTR — users were hitting
# 404 or homepage and bouncing. 301 to the closest equivalent.
/car-finder                  /inventory/                       301
/car-finder/                 /inventory/                       301
/warranty                    /faq/                             301
/warranty/                   /faq/                             301

# ─── Print views (CarsForSale-era artifacts) ────────────────────────
# Old auto-CMS emitted /print/{stocknum} and /print/vehicle/{vin} for
# print-friendly VDPs. Those routes don't exist on this Next.js build
# and were previously blocked in robots.txt — but Google had old index
# entries that kept failing "validate fix" forever (the validator
# requires the URL to be reachable). 301 to inventory index so the
# legacy URL deindexes cleanly and any residual link equity consolidates.
# 2026-05-07 — Charlotte.
/print                       /inventory/                       301
/print/                      /inventory/                       301
/print/*                     /inventory/                       301

# ─── Blog routes (parked Apr 2026) ──────────────────────────────────
# Blog removed from public site but content preserved in src/data/blog.ts.
# Any inbound link to a blog post lands on /inventory rather than 404.
# When the blog comes back, delete these four lines.
/blog                        /inventory/                       301
/blog/                       /inventory/                       301
/blog/*                      /inventory/                       301

# ─── Old VDP slug patterns (CarsForSale-era) — added 2026-06-29, Leo ──
# Search Console "Not found (404)" report (June 2026) surfaced ~163 dead
# URLs. The bulk are legacy auto-CMS vehicle-detail pages plus a stray
# /default — never mapped at cutover, so they hard-404 and waste whatever
# Google equity they still hold. 301 to /inventory/ so equity consolidates
# and the legacy URLs deindex cleanly. Patterns confirmed from the live GSC
# 404 export: /Inventory/Details/{guid}, /default, /inventory/{brand}/{model}/{stock}.

# Legacy VDP detail pages: /Inventory/Details/{guid}
/Inventory/Details/*         /inventory/                       301
/inventory/details/*         /inventory/                       301

# Stray legacy homepage alias
/default                     /                                 301
/default/                    /                                 301

# Old brand/model/stock VDP format: /inventory/{brand}/{model}/{stock}
# e.g. /inventory/lexus/rc/11266. Live VDPs are single-segment
# (/inventory/{slug}/), so this 3-segment pattern cannot collide with a
# live car page or with the :slug rewrite below.
/inventory/:brand/:model/:stock   /inventory/                  301

# --- VDP / landing trailing-slash recovery (S56, 2026-06-16) ---
# Static export emits /<route>/index.html. Cloudflare auto-redirects the
# no-slash form for TOP-LEVEL routes but NOT for nested /inventory/<slug>,
# which hard-404s (verified 2026-06-16: bare VDP + /inventory/used-* both
# 404). Serve the canonical page via a 200 REWRITE (not a 301) so there is
# no redirect chain and no loop risk. Canonical/og tags already point at the
# slash form, so no duplicate-content penalty.
/inventory/:slug    /inventory/:slug/index.html    200
